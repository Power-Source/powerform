{
  "name": "powerform",
  "version": "1.2.1",
  "description": "WordPress form builder plugin - Create custom forms, polls, quizzes, and surveys with drag and drop",
  "private": true,
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "clean": "rm -rf assets/css/*.min.css assets/css/*.map assets/js/*.min.js assets/js/*.map assets/fonts/* assets/images/*",
    "lint:js": "eslint assets/js --ext .js --ignore-pattern *.min.js",
    "lint:css": "stylelint 'assets/scss/**/*.scss'",
    "format": "prettier --write 'assets/js/**/*.js' 'assets/scss/**/*.scss'"
  },
  "keywords": [
    "wordpress",
    "forms",
    "polls",
    "quiz",
    "survey",
    "contact-form"
  ],
  "author": "PS-Source",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "eslint": "^8.52.0",
    "file-loader": "^6.2.0",
    "mini-css-extract-plugin": "^2.10.0",
    "postcss": "^8.4.31",
    "postcss-loader": "^7.3.3",
    "prettier": "^3.0.3",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "style-loader": "^3.3.3",
    "stylelint": "^15.11.0",
    "stylelint-config-standard-scss": "^11.0.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
